<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activeInputRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp">

    <CheckBox
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:enabled="false"
        android:layout_marginEnd="12dp"/>

    <EditText
        android:id="@+id/etNewTodoInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:hint="KEY IN YOUR NEW TODO"
        android:textColorHint="#998B5A2B"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#000000"
        android:padding="12dp"
        android:background="@drawable/border_active_input"
        android:inputType="textCapSentences"
        android:maxLines="1"
        android:singleLine="true"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:paddingHorizontal="4dp"
        android:layout_marginVertical="2dp"
        android:background="@drawable/border_rounded_box">

        <ImageButton
            android:id="@+id/btnConfirmNewTodo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/checkbox_on_background"
            app:tint="#4CAF50"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <ImageButton
            android:id="@+id/btnCancelNewTodo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#F44336"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>

</LinearLayout>