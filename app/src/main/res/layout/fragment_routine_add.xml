<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FAF4EB"
    android:padding="20dp">

    <ImageView
        android:id="@+id/ivTaskUser"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:src="@android:drawable/ic_menu_myplaces"
        app:tint="@color/accent_brown"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <RadioGroup
        android:id="@+id/rgTaskTypeAddScreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/ivTaskUser">

        <RadioButton
            android:id="@+id/rbRoutine"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:text="Routine"
            android:button="@null"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:textStyle="bold"
            android:checked="true"
            android:textColor="@color/selector_toggle_text"
            android:background="@drawable/bg_toggle_left"/>

        <RadioButton
            android:id="@+id/rbTodo"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:text="To-do"
            android:button="@null"
            android:paddingHorizontal="16dp"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/selector_toggle_text"
            android:background="@drawable/bg_toggle_right"/>
    </RadioGroup>

    <View
        android:id="@+id/topDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#000000"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivTaskUser"/>

    <EditText
        android:id="@+id/etRoutineTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="WEEKEND ROUTINE"
        android:textColorHint="#888888"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textSize="20sp"
        android:padding="16dp"
        android:background="@drawable/border_rounded_box"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/topDivider"
        android:layout_marginTop="20dp"/>

    <LinearLayout
        android:id="@+id/layoutDays"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/etRoutineTitle">

        <CheckBox
            android:id="@+id/cbMon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/selector_day_toggle"
            android:button="@null"
            android:text="mo"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/selector_day_text" />

        <CheckBox
            android:id="@+id/cbTue"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/selector_day_toggle"
            android:button="@null"
            android:text="tu"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/selector_day_text" />

        <CheckBox
            android:id="@+id/cbWed"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/selector_day_toggle"
            android:button="@null"
            android:text="we"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/selector_day_text" />

        <CheckBox
            android:id="@+id/cbThu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/selector_day_toggle"
            android:button="@null"
            android:text="th"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/selector_day_text" />

        <CheckBox
            android:id="@+id/cbFri"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/selector_day_toggle"
            android:button="@null"
            android:text="fr"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/selector_day_text" />

        <CheckBox
            android:id="@+id/cbSat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/selector_day_toggle"
            android:button="@null"
            android:text="sa"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/selector_day_text" />

        <CheckBox
            android:id="@+id/cbSun"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/selector_day_toggle"
            android:button="@null"
            android:text="su"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/selector_day_text" />
    </LinearLayout>

    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#000000"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDays"/>

    <TextView
        android:id="@+id/tvReminderLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reminder"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="#000000"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/divider1"
        app:layout_constraintStart_toStartOf="parent"/>

    <Switch
        android:id="@+id/switchReminder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:scaleX="1.3"
        android:scaleY="1.3"
        app:layout_constraintTop_toTopOf="@id/tvReminderLabel"
        app:layout_constraintBottom_toBottomOf="@id/tvReminderLabel"
        app:layout_constraintStart_toEndOf="@id/tvReminderLabel"/>

    <RadioGroup
        android:id="@+id/rgReminderType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvReminderLabel">

        <RadioButton
            android:id="@+id/rbAlarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alarm"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_weight="1"/>

        <RadioButton
            android:id="@+id/rbPush"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Push"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:checked="true"
            android:layout_weight="1"/>
    </RadioGroup>

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#000000"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/rgReminderType"/>

    <LinearLayout
        android:id="@+id/layoutTimeSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/divider2">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Starts at"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#000000"/>

        <LinearLayout
            android:id="@+id/btnOpenTimePicker"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:background="@drawable/border_rounded_box"
            android:backgroundTint="#D6D5DB"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvTimeDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20 : 00"
                android:textSize="48sp"
                android:textColor="#000000"/>

            <TextView
                android:id="@+id/tvAmPm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PM"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabConfirmRoutine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_done"
        app:backgroundTint="#C18A58"
        app:tint="@color/white"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>