<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panelJournalListView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <TextView
            android:id="@+id/tvPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How's your day?"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvJournal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvPrompt"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddJournal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="Add Journal Entry"
            android:backgroundTint="@color/accent_brown"
            app:tint="@android:color/white"
            android:layout_margin="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panelJournalEditWorkspace"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnWorkspaceBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="?attr/homeAsUpIndicator"
            android:contentDescription="Back"
            android:background="@android:color/transparent"
            app:tint="@color/accent_brown"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <ImageButton
            android:id="@+id/btnWorkspaceSave"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_save"
            android:contentDescription="Save Entry"
            android:background="@android:color/transparent"
            app:tint="@color/accent_brown"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etJournalTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Title..."
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:importantForAutofill="no"
            android:inputType="textCapSentences"
            android:background="@drawable/bg_rounded_card"
            android:paddingHorizontal="12dp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnWorkspaceBack"/>

        <EditText
            android:id="@+id/etJournalContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:hint="Start writing your thoughts here..."
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:background="@drawable/bg_rounded_card"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/etJournalTitle"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>