<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="70dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_rounded_card"
    android:padding="10dp">
    <TextView android:id="@+id/tvDateBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00/00/00" android:textSize="10sp" android:textColor="@android:color/darker_gray" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <TextView android:id="@+id/tvJournalRowTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Journal Subject Line" android:textColor="@color/text_dark" android:textStyle="bold" android:textSize="16sp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <ImageButton android:id="@+id/btnJournalDelete" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_delete" android:background="@android:color/transparent" app:tint="@color/accent_orange" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>