<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivProfileAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:contentDescription="Profile Icon"
                app:tint="@color/accent_brown"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tvWelcomeHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WELCOME BACK, USER"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toTopOf="@id/ivProfileAvatar"
                app:layout_constraintBottom_toBottomOf="@id/ivProfileAvatar"
                app:layout_constraintStart_toEndOf="@id/ivProfileAvatar" />

            <LinearLayout
                android:id="@+id/layoutStreakTracker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_rounded_card"
                android:padding="12dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/ivProfileAvatar">

                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="1" android:gravity="center" android:background="@drawable/bg_streak_active" android:textColor="@android:color/white" android:layout_margin="2dp"/>
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="2" android:gravity="center" android:background="@drawable/bg_streak_active" android:textColor="@android:color/white" android:layout_margin="2dp"/>
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="3" android:gravity="center" android:background="@drawable/bg_streak_inactive" android:textColor="@color/accent_brown" android:layout_margin="2dp"/>
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="4" android:gravity="center" android:background="@drawable/bg_streak_inactive" android:textColor="@color/accent_brown" android:layout_margin="2dp"/>
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="5" android:gravity="center" android:background="@drawable/bg_streak_inactive" android:textColor="@color/accent_brown" android:layout_margin="2dp"/>
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="6" android:gravity="center" android:background="@drawable/bg_streak_inactive" android:textColor="@color/accent_brown" android:layout_margin="2dp"/>
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="7" android:gravity="center" android:background="@drawable/bg_streak_inactive" android:textColor="@color/accent_brown" android:layout_margin="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTodoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reminder :\nTO-DO"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/layoutStreakTracker"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/panelChartContainer"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_rounded_card"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvTodoLabel">

                <View
                    android:id="@+id/mockPieChart"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_mock_pie_chart"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tvOverallProgress"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/layoutLegend"/>

                <LinearLayout
                    android:id="@+id/layoutLegend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/mockPieChart">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="■ 25% COMPLETED" android:textColor="@color/accent_green" android:textStyle="bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="■ 75% INCOMPLETE" android:textColor="@color/accent_orange" android:textStyle="bold" android:textSize="12sp" android:layout_marginTop="8dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvOverallProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OVERALL COMPLETION METRICS"
                    android:textColor="@color/accent_brown"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tvRoutineLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUTINE COMPLETION"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/panelChartContainer"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardWeekendRoutine"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_rounded_card"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvRoutineLabel">

                <TextView
                    android:id="@+id/tvWeekendPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="67%"
                    android:gravity="center"
                    android:textColor="@color/accent_brown"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"/>

                <View
                    android:id="@+id/divider1"
                    android:layout_width="1dp"
                    android:layout_height="30dp"
                    android:background="@color/divider_gray"
                    android:layout_marginStart="12dp"
                    app:layout_constraintStart_toEndOf="@id/tvWeekendPercent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="WEEKEND ROUTINE"
                    android:gravity="center"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/divider1"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardNightRoutine"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_routine_complete"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@id/cardWeekendRoutine">

                <TextView
                    android:id="@+id/tvNightPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="100%"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"/>

                <View
                    android:id="@+id/divider2"
                    android:layout_width="1dp"
                    android:layout_height="30dp"
                    android:background="#A3CBB7"
                    android:layout_marginStart="12dp"
                    app:layout_constraintStart_toEndOf="@id/tvNightPercent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="NIGHT ROUTINE"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toEndOf="@id/divider2"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@color/card_white"
        app:itemIconTint="@color/accent_brown"
        app:itemTextColor="@color/text_dark"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>