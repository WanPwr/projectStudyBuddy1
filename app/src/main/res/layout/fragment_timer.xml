<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/timer_bg"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivTimerUser"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_myplaces"
        android:contentDescription="User Avatar"
        app:tint="@color/accent_brown"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!--Timer circle border-->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/timerCircle"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:background="@drawable/circle_border"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/ivTimerUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCountdownDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="00:00:00"
            android:fontFamily="@font/digital_7"
            android:textColor="@color/text_dark"
            android:textSize="36sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!--Start and reset button-->
    <LinearLayout
        android:id="@+id/layoutTimerControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/timerCircle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnTimerToggle"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="▶ Start"
            android:backgroundTint="@color/blue_btn"
            android:textColor="@color/white"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btnTimerReset"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="⟳ Restart"
            android:backgroundTint="@color/org_btn"
            android:textColor="@color/white"/>
    </LinearLayout>

    <!--Preset timers-->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignBounds"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTimerControls">

        <Button
            android:id="@+id/btnPreset100"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="00:00:10" />

        <Button
            android:id="@+id/btnPreset10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="00:10:00" />

        <Button
            android:id="@+id/btnPreset30"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="00:30:00" />

        <Button
            android:id="@+id/btnPreset45"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="00:45:00" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>