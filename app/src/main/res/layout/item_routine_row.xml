<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="55dp"
    android:layout_marginBottom="10dp"
    android:paddingHorizontal="16dp">
    <TextView android:id="@+id/tvRoutinePercent" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="0%" android:gravity="center" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent"/>
    <TextView android:id="@+id/tvRoutineName" android:layout_width="wrap_content" android:layout_height="match_parent" android:text="ROUTINE" android:gravity="center" android:textStyle="bold" android:layout_marginStart="40dp" app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>