<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#8B5A2B"/>
            <corners android:topLeftRadius="50dp" android:bottomLeftRadius="50dp"/>
        </shape>
    </item>
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <solid android:color="#D3D3D3"/>
            <corners android:topLeftRadius="50dp" android:bottomLeftRadius="50dp"/>
        </shape>
    </item>
</selector><!--Because the toggle is a pill shape, the left side (Routine)
has rounded left corners, and the right side (To-do) has rounded right corners-->